  "info": {
    "title": "TeamForge API",
    "description": "The Student Project Collaboration Platform REST API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "Collaborator",
              "Project Owner",
              "Mentor",
              "Administrator",
              "Super User"
            ],
            "example": "Collaborator"
          },
          "skills": {
            "example": [
              "React",
              "NestJS"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "linkedIn": {
            "type": "string",
            "example": "https://linkedin.com/in/johndoe"
          },
          "status": {
            "type": "string",
            "enum": [
              "Active",
              "Suspended",
              "Warned"
            ],
            "default": "Active"
          },
          "flags": {
            "type": "boolean",
            "example": false,
            "default": false
          }
        },
        "required": [
          "name",
          "email",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "Collaborator",
              "Project Owner",
              "Mentor",
              "Administrator",
              "Super User"
            ],
            "example": "Collaborator"
          },
          "skills": {
            "example": [
              "React",
              "NestJS"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "linkedIn": {
            "type": "string",
            "example": "https://linkedin.com/in/johndoe"
          },
          "status": {
            "type": "string",
            "enum": [
              "Active",
              "Suspended",
              "Warned"
            ],
            "default": "Active"
          },
          "flags": {
            "type": "boolean",
            "example": false,
            "default": false
          }
        }
      },
      "CreateProjectDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "AI Study Planner"
          },
          "description": {
            "type": "string",
            "example": "An intelligent study scheduling app."
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "Easy",
              "Medium",
              "Hard"
            ],
            "example": "Medium"
          },
          "requiredSkills": {
            "example": [
              "React",
              "Python",
              "ML"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "duration": {
            "type": "string",
            "example": "3 Months"
          }
        },
        "required": [
          "title",
          "description",
          "difficulty",
          "requiredSkills",
          "duration"
        ]
      },
      "UpdateProjectDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "AI Study Planner"
          },
          "description": {
            "type": "string",
            "example": "An intelligent study scheduling app."
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "Easy",
              "Medium",
              "Hard"
            ],
            "example": "Medium"
          },
          "requiredSkills": {
            "example": [
              "React",
              "Python",
              "ML"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "duration": {
            "type": "string",
            "example": "3 Months"
          }
        }
      },
      "CreateTaskDto": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "example": "proj-1"
          },
          "title": {
            "type": "string",
            "example": "Design Database Schema"
          },
          "description": {
            "type": "string",
            "example": "Create the ERD and define the tables for the backend."
          },
          "xpReward": {
            "type": "number",
            "example": 50,
            "description": "XP awarded upon completion"
          },
          "status": {
            "type": "string",
            "enum": [
              "To Do",
              "In Progress",
              "In Review",
              "Completed"
            ],
            "default": "To Do"
          },
          "assigneeId": {
            "type": "string",
            "example": "2"
          }
        },
        "required": [
          "projectId",
          "title",
          "description",
          "xpReward"
        ]
      },
      "UpdateTaskDto": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "example": "proj-1"
          },
          "title": {
            "type": "string",
            "example": "Design Database Schema"
          },
          "description": {
            "type": "string",
            "example": "Create the ERD and define the tables for the backend."
          },
          "xpReward": {
            "type": "number",
            "example": 50,
            "description": "XP awarded upon completion"
          },
          "status": {
            "type": "string",
            "enum": [
              "To Do",
              "In Progress",
              "In Review",
              "Completed"
            ],
            "default": "To Do"
          },
          "assigneeId": {
            "type": "string",
            "example": "2"
          }
        }
      }
    }
  }
}